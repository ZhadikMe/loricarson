		<title>The Experience of All That</title>
		<link>http://lifeandmusic.loricarson.com/?p=1190</link>
		<comments>http://lifeandmusic.loricarson.com/?p=1190#comments</comments>
		<pubDate>Fri, 20 Sep 2013 13:10:33 +0000</pubDate>
